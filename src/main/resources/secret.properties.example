# Copy this file to secret.properties and fill in real values.
# secret.properties is gitignored and must never be committed.

# JWT signing secret — minimum 32 characters
jwt.secret=change-me-to-a-long-random-string-32chars

# LDAP bind password for uid=fd-admin,ou=people,dc=chatco,dc=net
ldap.password=

# PostgreSQL password for appuser
# Local dev default (matches docker-compose.yml): devpassword
db.password=devpassword

# Truststore password for truststore.jks (LDAPS TLS)
# Leave blank if you have no truststore.jks locally
truststore.password=
